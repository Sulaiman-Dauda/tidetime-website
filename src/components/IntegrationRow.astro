---
const calendarIcon = `<rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>`;
const videoIcon = `<polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/>`;
const crmIcon = `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`;
const cardIcon = `<rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/>`;
const mailIcon = `<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>`;

const groups = [
  {
    label: "Calendars",
    items: [
      { name: "Google Calendar", icon: calendarIcon },
      { name: "Microsoft 365 / Outlook", icon: calendarIcon },
      { name: "Apple / CalDAV", icon: calendarIcon },
    ],
  },
  {
    label: "Conferencing",
    items: [
      { name: "Google Meet", icon: videoIcon },
      { name: "Microsoft Teams", icon: videoIcon },
      { name: "Zoom", icon: videoIcon },
      { name: "Daily", icon: videoIcon },
      { name: "Jitsi", icon: videoIcon, tag: "built-in" },
    ],
  },
  {
    label: "Business",
    items: [
      { name: "Stripe", icon: cardIcon },
      { name: "HubSpot", icon: crmIcon },
      { name: "SMTP email", icon: mailIcon },
    ],
  },
];
---

<section class="tt-section tt-page" id="integrations">
  <div class="tt-inner">

    <div class="tt-section-head tt-reveal">
      <span class="tt-eyebrow">
        <span class="tt-eyebrow-dot"></span>
        Integrations
      </span>
      <h2 class="tt-section-heading">Works with the tools<br>you already use.</h2>
      <p class="tt-section-lead">
        Credentials are stored encrypted in your database and configured in-app — or supplied as environment variables.
        Your keys never leave your server.
      </p>
    </div>

    <div class="tt-int-groups tt-reveal" style="--tt-delay: 0.08s">
      {groups.map((group) => (
        <div class="tt-int-group">
          <div class="tt-int-group-label">{group.label}</div>
          <div class="tt-int-group-items">
            {group.items.map((item) => (
              <span class="tt-int-pill">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={item.icon} />
                {item.name}
                {item.tag && <span class="tt-int-tag">{item.tag}</span>}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <p class="tt-int-note tt-reveal" style="--tt-delay: 0.14s">
      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
      </svg>
      All credentials are encrypted at rest. Nothing is shared with third-party services.
    </p>

  </div>
</section>
