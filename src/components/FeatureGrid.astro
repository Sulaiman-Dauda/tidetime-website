---
---

<section class="tt-section tt-page">
  <div class="tt-inner">

    <div class="tt-section-head">
      <span class="tt-eyebrow">
        <span class="tt-eyebrow-dot"></span>
        Capabilities
      </span>
      <h2 class="tt-section-heading">Everything a scheduling<br>platform should have.</h2>
      <p class="tt-section-lead">
        From a single consultant link to a full team operation — Tidetime scales with you without switching tools.
      </p>
    </div>

    <div class="tt-feature-grid">

      <!-- Booking pages -->
      <div class="tt-feature-card">
        <div class="tt-feature-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
        </div>
        <h3>Booking pages</h3>
        <p>Shareable personal and team pages with your branding, custom questions, durations, buffers, and notice rules.</p>
      </div>

      <!-- Team scheduling -->
      <div class="tt-feature-card">
        <div class="tt-feature-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </div>
        <h3>Team scheduling</h3>
        <p>Round-robin, collective, and multi-attendant assignment with role-based access for your whole team.</p>
      </div>

      <!-- Calendar sync -->
      <div class="tt-feature-card">
        <div class="tt-feature-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="23 4 23 10 17 10"/>
            <polyline points="1 20 1 14 7 14"/>
            <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
          </svg>
        </div>
        <h3>Calendar sync</h3>
        <p>Two-way sync with Google Calendar, Microsoft 365 / Outlook, and Apple / CalDAV. No double-bookings.</p>
      </div>

      <!-- Meeting links -->
      <div class="tt-feature-card">
        <div class="tt-feature-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="23 7 16 12 23 17 23 7"/>
            <rect x="1" y="5" width="15" height="14" rx="2" ry="2"/>
          </svg>
        </div>
        <h3>Automatic meeting links</h3>
        <p>Google Meet, Teams, Zoom, Daily, or built-in Jitsi — minted per booking with no manual steps.</p>
      </div>

      <!-- Payments -->
      <div class="tt-feature-card">
        <div class="tt-feature-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/>
            <line x1="1" y1="10" x2="23" y2="10"/>
          </svg>
        </div>
        <h3>Payments &amp; deposits</h3>
        <p>Collect full payment or a deposit at booking time with Stripe. Confirmations and refunds handled automatically.</p>
      </div>

      <!-- Meeting polls -->
      <div class="tt-feature-card">
        <div class="tt-feature-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 11 12 14 22 4"/>
            <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
          </svg>
        </div>
        <h3>Meeting polls</h3>
        <p>Propose several time slots, let invitees vote, and book the winning time — with flexible result visibility.</p>
      </div>

      <!-- Routing forms -->
      <div class="tt-feature-card">
        <div class="tt-feature-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <line x1="6" y1="3" x2="6" y2="15"/>
            <circle cx="18" cy="6" r="3"/>
            <circle cx="6" cy="18" r="3"/>
            <path d="M18 9a9 9 0 0 1-9 9"/>
          </svg>
        </div>
        <h3>Routing forms</h3>
        <p>Ask a few questions, then route each person to the right service, an external URL, or a custom message.</p>
      </div>

      <!-- Reviews -->
      <div class="tt-feature-card">
        <div class="tt-feature-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
          </svg>
        </div>
        <h3>Reviews</h3>
        <p>Collect private feedback and route happy clients to your public review page above a configurable star threshold.</p>
      </div>

      <!-- Reminders -->
      <div class="tt-feature-card">
        <div class="tt-feature-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
            <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
          </svg>
        </div>
        <h3>Reminders &amp; emails</h3>
        <p>Branded confirmations, reschedules, cancellations, and timed reminders sent over your own SMTP server.</p>
      </div>

    </div>
  </div>
</section>
